@startuml
title Lifecycle Workflow - Data Flow
!pragma layout smetana
skinparam shadowing false

rectangle "entry.setting\nstrategy_full_config\nconfig/*.toml" as config_input
rectangle "LifecycleWorkflow" as workflow
rectangle "Service activation\n+ strategy contracts" as services
rectangle "Aggregates\nInstrument / Position / Combination" as aggregates
rectangle "Gateways + persistence\n+ monitor" as infrastructure
rectangle "Warmup / restore\nhistory + OMS state" as warmup
rectangle "Ready StrategyEntry" as output

config_input --> workflow : load + normalize
workflow --> services : build domain services
workflow --> aggregates : init or restore
workflow --> infrastructure : create gateways,\nmonitor, autosave
workflow --> warmup : replay or sync
services --> output
aggregates --> output
infrastructure --> output
warmup --> output
@enduml
