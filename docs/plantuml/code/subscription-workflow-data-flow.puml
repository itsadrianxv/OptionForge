@startuml
title Subscription Workflow - Data Flow
!pragma layout smetana
skinparam shadowing false

rectangle "subscription_config" as config
rectangle "Active contracts\nby product" as active_contracts
rectangle "Position + pending\norder symbols" as live_symbols
rectangle "Temporary signal\nsymbols (TTL)" as temp_symbols
rectangle "SubscriptionRuntimeContext" as context
rectangle "SubscriptionModeEngine" as engine
rectangle "Target symbols" as target_symbols
rectangle "Gateway subscribe /\nunsubscribe calls" as gateway

config --> context
active_contracts --> context
live_symbols --> context
temp_symbols --> context
context --> engine : resolve()
engine --> target_symbols : decision.target_symbols
target_symbols --> gateway : reconcile current subscriptions
@enduml
