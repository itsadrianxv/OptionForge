@startuml
title Market Workflow - Data Flow
!pragma layout smetana
skinparam shadowing false

rectangle "TickData / BarData" as input
rectangle "Rollover + universe checks" as universe
rectangle "Instrument update" as instrument
rectangle "Option chain snapshot" as chain
rectangle "Indicator result" as indicator
rectangle "Open pipeline\nsignal -> selection -> pricing -> sizing" as open_pipeline
rectangle "Close pipeline\nsignal -> close plan" as close_pipeline
rectangle "DecisionTrace payloads" as traces
rectangle "Snapshot / autosave /\nsubscription refresh" as outputs

input --> universe : on_bars
universe --> instrument : active contract state
instrument --> chain : underlying price + contracts
chain --> indicator : enriched context
indicator --> open_pipeline : open decision
indicator --> close_pipeline : close decision
open_pipeline --> traces : open trace
close_pipeline --> traces : close trace
traces --> outputs : journal / monitor / snapshot
@enduml
