@startuml
title State Workflow - Data Flow
!pragma layout smetana
skinparam shadowing false

rectangle "Target aggregate snapshot" as target
rectangle "Position aggregate snapshot" as positions
rectangle "Combination aggregate snapshot" as combinations
rectangle "StateWorkflow" as workflow
rectangle "Snapshot dict" as snapshot
rectangle "Monitor storage" as monitor

target --> workflow
positions --> workflow
combinations --> workflow : optional
workflow --> snapshot : create_snapshot()
workflow --> monitor : record_snapshot(...)
@enduml
